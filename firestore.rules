rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isSignedIn() && getUserData().role == 'admin'; }
    function isGuru() { return isSignedIn() && (getUserData().role == 'guru' || getUserData().role == 'admin'); }
    function isStaff() { return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'guru' || getUserData().role == 'admin'); }
    function isSiswa() { return isSignedIn() && getUserData().role == 'siswa'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.username is string && data.username.size() <= 50 &&
               data.role in ['admin', 'guru', 'staff', 'siswa'] &&
               data.fullName is string && data.fullName.size() <= 100;
      }
      
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'username']));
      allow delete: if isAdmin();
    }

    // Students Collection
    match /students/{nisn} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Attendance Collection
    match /attendance/{attendanceId} {
      allow read: if isStaff();
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn(); // Simplified for now, should check if they are reporting for themselves or students
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Exams and Questions
    match /exams/{examId} {
      allow read: if isSignedIn();
      allow write: if isGuru();

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow write: if isGuru();
      }
    }

    // Exam Results
    match /examResults/{resultId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isGuru());
      allow list: if isGuru() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSiswa() && request.resource.data.studentId == request.auth.uid;
      allow update: if isGuru();
      allow delete: if isAdmin();
    }
  }
}
